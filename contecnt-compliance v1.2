// ─── Sentence utils ───────────────────────────────────────────────────────────
function splitSentences(text){
  const raw=(text||'').replace(/\r/g,'\n').trim();
  if(!raw) return [];
  return raw.replace(/\n+/g,' ').replace(/\s+/g,' ')
    .replace(/([.!?。！？])\s+/g,'$1\n')
    .split(/\n+/).map(x=>x.trim()).filter(Boolean);
}
function norm(t){return(t||'').replace(/\s+/g,' ').trim()}
function soft(t){return norm(t).replace(/["'""''.,!?()[\]{}:;。，！？]/g,'').toLowerCase()}

function buildLookup(flags,sentences){
  const byIdx=new Map(),byExact=new Map(),bySoft=new Map();
  flags.forEach(f=>{
    const i=Number(f.sentence_index);
    if(Number.isInteger(i)&&i>0) byIdx.set(i-1,f);
    if(f.sentence){byExact.set(norm(f.sentence),f);bySoft.set(soft(f.sentence),f);}
  });
  const out=new Map();
  sentences.forEach((sent,i)=>{
    if(byExact.has(norm(sent))) return out.set(i,byExact.get(norm(sent)));
    if(byIdx.has(i)) return out.set(i,byIdx.get(i));
    const sk=soft(sent);
    if(bySoft.has(sk)) return out.set(i,bySoft.get(sk));
    for(const[k,f] of bySoft){if(k&&sk&&(k.includes(sk)||sk.includes(k))){out.set(i,f);return;}}
  });
  return out;
}

// ─── Render ───────────────────────────────────────────────────────────────────
function renderOriginal(sentences,matched){
  const el=$('originalList');
  el.innerHTML='';
  if(!sentences.length){el.innerHTML=`<div class="empty">${s('noCompliance')}</div>`;return;}
  sentences.forEach((txt,i)=>{
    const d=document.createElement('div');
    d.className='sent-item'+(matched.get(i)?' flagged':'');
    d.innerHTML=`<span class="sent-num">${s('sentence',i+1)}</span>${esc(txt)}`;
    el.appendChild(d);
  });
}

function renderFeedback(sentences,matched){
  const el=$('feedbackList');
  el.innerHTML='';
  if(!sentences.length){el.innerHTML=`<div class="empty">${s('noCompliance')}</div>`;return;}
  sentences.forEach((txt,i)=>{
    const flag=matched.get(i);
    const d=document.createElement('div');
    if(!flag){
      d.className='fb-item';
      d.innerHTML=`<span class="sent-num">${s('sentence',i+1)}</span><span class="fb-clean">${s('noCompliance')}</span>`;
    } else {
      const sev=(flag.severity||'low').toLowerCase();
      d.className=`fb-item ${sev}`;
      d.innerHTML=`<span class="sent-num">${s('sentence',i+1)}</span>
        <p><strong>${s('reason')}:</strong> ${esc(flag.reason||'-')}</p>
        <p><strong>${s('revision')}:</strong> ${esc(flag.suggested_revision||'-')}</p>
        <p><strong>${s('guideBasis')}:</strong> ${esc(flag.guide_basis||'-')}</p>`;
    }
    el.appendChild(d);
  });
}

function renderRevised(data,flags){
  const box=$('revisedDraftBox');
  const rev=(data.revised_draft||'').trim();
  const fallback=flags.map(f=>f.suggested_revision).filter(Boolean).join(' ');
  const text=rev||fallback||s('noRevised');
  box.textContent=text;
  box.classList.toggle('has-content',!!(rev||fallback));
}

function renderFlags(flags){
  const el=$('flagList');
  el.innerHTML='';
  if(!flags.length){el.innerHTML=`<div class="empty">${s('noFlags')}</div>`;return;}
  flags.forEach((flag,i)=>{
    const sev=(flag.severity||'low').toLowerCase();
    const d=document.createElement('div');
    d.className='flag-item';
    d.innerHTML=`
      <div class="flag-meta">
        <span class="badge ${sev}">${esc((flag.severity||'low').toUpperCase())}</span>
        <span class="badge type">${esc(flag.risk_type||'unknown')}</span>
        <span style="font-size:11px;color:var(--faint)">${s('flag',i+1)}</span>
      </div>
      <div class="flag-quote">${esc(flag.sentence||'')}</div>
      <div class="flag-detail"><strong>${s('reason')}:</strong> ${esc(flag.reason||'-')}</div>
      <div class="flag-detail"><strong>${s('revision')}:</strong> ${esc(flag.suggested_revision||'-')}</div>
      <div class="flag-detail"><strong>${s('guideBasis')}:</strong> ${esc(flag.guide_basis||'-')}</div>`;
    el.appendChild(d);
  });
}

// ─── JSON extract ─────────────────────────────────────────────────────────────
function extractJson(raw){
  if(!raw) return null;
  const fenced=raw.match(/```json\s*([\s\S]*?)```/i)||raw.match(/```\s*([\s\S]*?)```/i);
  if(fenced) return fenced[1].trim();
  const start=raw.indexOf('{'); if(start===-1) return null;
  let depth=0,inStr=false,esc_=false;
  for(let i=start;i<raw.length;i++){
    const c=raw[i];
    if(inStr){if(esc_)esc_=false;else if(c==='\\')esc_=true;else if(c==='"')inStr=false;continue;}
    if(c==='"')inStr=true;else if(c==='{')depth++;else if(c==='}'){depth--;if(depth===0)return raw.slice(start,i+1);}
  }
  return null;
}

// ─── API Key Management ───────────────────────────────────────────────────────
function getApiKey(){ return localStorage.getItem('kupa_api_key')||''; }
function getModel(){ return localStorage.getItem('kupa_model')||'claude-sonnet-4-6'; }

function openApiKeyDialog(){
  const overlay=$('apiKeyOverlay');
  overlay.style.display='flex';
  $('apiKeyInput').value=getApiKey();
  $('modelSelect').value=getModel();
  $('apiKeyInput').focus();
}
function closeApiKeyDialog(){
  $('apiKeyOverlay').style.display='none';
}
function saveApiKey(){
  const key=$('apiKeyInput').value.trim();
  const model=$('modelSelect').value;
  if(key) localStorage.setItem('kupa_api_key',key);
  localStorage.setItem('kupa_model',model);
  updateApiKeyBtnState();
  closeApiKeyDialog();
}
function updateApiKeyBtnState(){
  const btn=$('apiKeyBtn');
  const hasKey=!!getApiKey();
  btn.style.borderColor=hasKey?'var(--ok)':'var(--err)';
  btn.style.color=hasKey?'var(--ok)':'var(--err)';
}
document.addEventListener('click', e=>{
  if(e.target===$('apiKeyOverlay')) closeApiKeyDialog();
});

// ─── Analyze ──────────────────────────────────────────────────────────────────
async function analyze(){
  const apiKey=getApiKey();
  if(!apiKey){
    openApiKeyDialog();
    setStatus(s('statusNoApiKey'),'err');
    return;
  }
  const draftVal=draft.value.trim();
  if(!draftVal){ setStatus(s('statusReady'),'warn'); return; }
  setStatus(s('statusAnalyzing'),'',true);
  $('analyzeBtn').disabled=true;

  const promptText=PROMPT[lang](
    persona.value||'-', topic.value||'-', message.value||'-', draftVal
  );

  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key': apiKey,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body:JSON.stringify({
        model: getModel(),
        max_tokens:4096,
        messages:[{role:'user',content:promptText}]
      })
    });
    if(!res.ok){ const e=await res.json(); throw new Error(e.error?.message||`HTTP ${res.status}`); }
    const apiData=await res.json();
    const rawText=apiData.content[0].text;
    const jsonText=extractJson(rawText);
    if(!jsonText) throw new Error('JSON not found in response');
    const data=JSON.parse(jsonText);
    const sentences=splitSentences(draftVal);
    const flags=Array.isArray(data.flags)?data.flags:[];
    const matched=buildLookup(flags,sentences);
    renderOriginal(sentences,matched);
    renderFeedback(sentences,matched);
    renderRevised(data,flags);
    renderFlags(flags);
    setSummaryResult(data,flags);
    setStatus(s('statusDone',sentences.length,flags.length),'ok');
  } catch(e){
    setStatus(s('statusError',e.message),'err');
    setSummaryIdle();
  } finally {
    $('analyzeBtn').disabled=false;
  }
}

