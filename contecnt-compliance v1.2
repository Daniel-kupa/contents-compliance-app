    icon.innerHTML=`<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`;
  } else {
    icon.innerHTML=`<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
  }
}

// ─── Wire ─────────────────────────────────────────────────────────────────────
function init(){
  $('analyzeBtn').addEventListener('click',analyze);
  $('loadDemoBtn').addEventListener('click',loadDemo);
  $('themeToggle').addEventListener('click',toggleTheme);
  $('langToggle').addEventListener('change',()=>{
    lang=$('langToggle').checked?'en':'ko';
    applyLang();
  });
  applyLang();
  setSummaryIdle();
  setRevisedPlaceholder();
  updateApiKeyBtnState();
  if(!getApiKey()) setTimeout(openApiKeyDialog, 400); // 처음 열면 자동으로 API 키 다이얼로그 표시
  $('originalList').innerHTML=`<div class="empty">${STR.ko.summaryIdleBody}</div>`;
  $('feedbackList').innerHTML=`<div class="empty">${STR.ko.summaryIdleBody}</div>`;
  $('flagList').innerHTML=`<div class="empty">${STR.ko.noFlags}</div>`;
}

document.readyState==='loading'?document.addEventListener('DOMContentLoaded',init):init();
</script>
</body>
</html>
